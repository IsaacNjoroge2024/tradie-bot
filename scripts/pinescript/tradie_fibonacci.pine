// scripts/pinescript/tradie_fibonacci.pine
//@version=5
indicator("Tradie - Fibonacci Levels", overlay=true)

// ============================================
// INPUTS
// ============================================
i_swingLen     = input.int(20, "Swing Detection Length", minval=5, maxval=50, group="Detection")
i_show236      = input.bool(false, "Show 0.236", group="Levels")
i_show382      = input.bool(true,  "Show 0.382", group="Levels")
i_show500      = input.bool(true,  "Show 0.500", group="Levels")
i_show618      = input.bool(true,  "Show 0.618 (Golden)", group="Levels")
i_show786      = input.bool(true,  "Show 0.786", group="Levels")
i_showExt1272  = input.bool(true,  "Show 1.272 Extension", group="Extensions")
i_showExt1618  = input.bool(true,  "Show 1.618 Extension", group="Extensions")
i_webhookSecret = input.string("TRADIE_SEC_9982", "Webhook Secret", group="Webhook")

// ============================================
// CALCULATIONS (all ta.* before any if blocks)
// ============================================
atr       = ta.atr(14)
swingHigh = ta.pivothigh(high, i_swingLen, i_swingLen)
swingLow  = ta.pivotlow(low,  i_swingLen, i_swingLen)

// EMA for trend direction
ema50 = ta.ema(close, 50)

sym = syminfo.ticker
pfx = syminfo.prefix
tf  = timeframe.period

// ============================================
// SWING TRACKING
// ============================================
var float fibHigh    = na
var float fibLow     = na
var int   fibHighBar = na
var int   fibLowBar  = na

if not na(swingHigh)
    fibHigh    := swingHigh
    fibHighBar := bar_index[i_swingLen]

if not na(swingLow)
    fibLow    := swingLow
    fibLowBar := bar_index[i_swingLen]

// ============================================
// FIBONACCI LEVELS
// Draw from swing low to swing high (bullish) or swing high to swing low (bearish)
// Retracement: pulling back toward previous origin
// Extension:   projecting beyond swing high/low (take profit targets)
// ============================================
fibRange = not na(fibHigh) and not na(fibLow) ? fibHigh - fibLow : na

// Retracement levels (measured from the bottom of the range up)
fib0    = not na(fibLow)   ? fibLow                           : na
fib236  = not na(fibRange) ? fibLow + fibRange * 0.236        : na
fib382  = not na(fibRange) ? fibLow + fibRange * 0.382        : na
fib500  = not na(fibRange) ? fibLow + fibRange * 0.500        : na
fib618  = not na(fibRange) ? fibLow + fibRange * 0.618        : na
fib786  = not na(fibRange) ? fibLow + fibRange * 0.786        : na
fib100  = not na(fibHigh)  ? fibHigh                          : na

// Extension levels (beyond the high — take profit targets)
fib1272 = not na(fibRange) ? fibHigh + fibRange * 0.272       : na
fib1618 = not na(fibRange) ? fibHigh + fibRange * 0.618       : na

// ============================================
// SIGNAL DETECTION
// Price touches key Fibonacci level and shows rejection candle
// ============================================
isBullCandle = close > open
isBearCandle = close < open
bodySize     = math.abs(close - open)
lowerWick    = math.min(close, open) - low
upperWick    = high - math.max(close, open)

trendBull = close > ema50
trendBear = close < ema50

// Helper: is price touching a fib level (within ATR tolerance)
touchFib(level) => not na(level) and math.abs(close - level) < atr * 0.3

// Bullish signals: price touches 0.382, 0.500, 0.618, or 0.786 in an uptrend and bounces
atFib382Bull = touchFib(fib382) and trendBull and isBullCandle and lowerWick > bodySize
atFib500Bull = touchFib(fib500) and trendBull and isBullCandle and lowerWick > bodySize
atFib618Bull = touchFib(fib618) and trendBull and isBullCandle and lowerWick > bodySize
atFib786Bull = touchFib(fib786) and trendBull and isBullCandle and lowerWick > bodySize

// Bearish signals: price touches 0.382, 0.500, 0.618, or 0.786 in a downtrend and rejects
atFib382Bear = touchFib(fib382) and trendBear and isBearCandle and upperWick > bodySize
atFib500Bear = touchFib(fib500) and trendBear and isBearCandle and upperWick > bodySize
atFib618Bear = touchFib(fib618) and trendBear and isBearCandle and upperWick > bodySize
atFib786Bear = touchFib(fib786) and trendBear and isBearCandle and upperWick > bodySize

bullSignal = atFib382Bull or atFib500Bull or atFib618Bull or atFib786Bull
bearSignal = atFib382Bear or atFib500Bear or atFib618Bear or atFib786Bear

// Strategy / level name
var string bullStrat = "FIB_BULL"
var string bearStrat = "FIB_BEAR"

if atFib618Bull
    bullStrat := "FIB_0618_BULL"
else if atFib786Bull
    bullStrat := "FIB_0786_BULL"
else if atFib500Bull
    bullStrat := "FIB_0500_BULL"
else if atFib382Bull
    bullStrat := "FIB_0382_BULL"

if atFib618Bear
    bearStrat := "FIB_0618_BEAR"
else if atFib786Bear
    bearStrat := "FIB_0786_BEAR"
else if atFib500Bear
    bearStrat := "FIB_0500_BEAR"
else if atFib382Bear
    bearStrat := "FIB_0382_BEAR"

// Confidence: golden ratio (0.618) and OTE zone (0.786) are highest probability
bullConf = atFib618Bull or atFib786Bull ? 80 : 68
bearConf = atFib618Bear or atFib786Bear ? 80 : 68

// SL / TP
bullSL = low  - atr * 0.5
bullTP = not na(fib100)  ? fib100  : close + (close - bullSL) * 2
bearSL = high + atr * 0.5
bearTP = not na(fib0)    ? fib0    : close - (bearSL - close) * 2

// ============================================
// PAYLOAD BUILDING (top-level)
// ============================================
bullP1 = '{"symbol":"' + sym + '","action":"BUY","strategy":"' + bullStrat + '"'
bullP2 = ',"price":' + str.tostring(close) + ',"stop_loss":' + str.tostring(bullSL) + ',"take_profit":' + str.tostring(bullTP)
bullP3 = ',"exchange":"' + pfx + '","timeframe":"' + tf
bullP4 = '","confidence":' + str.tostring(bullConf) + ',"auth_token":"' + i_webhookSecret + '"}'

bearP1 = '{"symbol":"' + sym + '","action":"SELL","strategy":"' + bearStrat + '"'
bearP2 = ',"price":' + str.tostring(close) + ',"stop_loss":' + str.tostring(bearSL) + ',"take_profit":' + str.tostring(bearTP)
bearP3 = ',"exchange":"' + pfx + '","timeframe":"' + tf
bearP4 = '","confidence":' + str.tostring(bearConf) + ',"auth_token":"' + i_webhookSecret + '"}'

// ============================================
// VISUALIZATION
// ============================================
plot(fib0,   "0.000",  color=color.new(color.gray,   0), linewidth=1)
plot(i_show236 ? fib236 : na, "0.236", color=color.new(color.gray,  30), linewidth=1)
plot(i_show382 ? fib382 : na, "0.382", color=color.new(color.blue,   0), linewidth=1)
plot(i_show500 ? fib500 : na, "0.500", color=color.new(color.gray,   0), linewidth=1)
plot(i_show618 ? fib618 : na, "0.618", color=color.new(color.orange,  0), linewidth=2)
plot(i_show786 ? fib786 : na, "0.786", color=color.new(color.red,    20), linewidth=1)
plot(fib100, "1.000",  color=color.new(color.gray,   0), linewidth=1)
plot(i_showExt1272 ? fib1272 : na, "1.272", color=color.new(color.purple, 20), linewidth=1)
plot(i_showExt1618 ? fib1618 : na, "1.618", color=color.new(color.purple,  0), linewidth=2)

// Signal labels
if bullSignal
    label.new(bar_index, low,  "BUY\n" + bullStrat,  style=label.style_label_up,   color=color.green, textcolor=color.white, size=size.small)

if bearSignal
    label.new(bar_index, high, "SELL\n" + bearStrat, style=label.style_label_down, color=color.red,   textcolor=color.white, size=size.small)

// ============================================
// WEBHOOK ALERTS
// ============================================
if bullSignal
    alert(bullP1 + bullP2 + bullP3 + bullP4, alert.freq_once_per_bar_close)

if bearSignal
    alert(bearP1 + bearP2 + bearP3 + bearP4, alert.freq_once_per_bar_close)
